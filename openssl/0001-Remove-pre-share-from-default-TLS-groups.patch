From 90740df4730177da352b543b0381e918e436b56c Mon Sep 17 00:00:00 2001
From: Dimitri John Ledkov <dimitri.ledkov@surgut.co.uk>
Date: Thu, 7 May 2026 10:49:40 +0100
Subject: [PATCH] Remove pre-share from default TLS groups

TLS_DEFAULT_GROUP_LIST is used without openssl.cnf to provide the
default set of TLS GROUPS that are supported for handshake. This list
includes two preshares for X25519MLKEM768 and X25519 in the
ClientHello. These preshares are larger than maximum packet size,
which causes AWS firewall to drop connections.

Remove the preshares, the negotiated group will then be shared in
subsequent packets, over the connection that AWS firewall will no
longer drop.

Note some test cases assume there is pre-share, thus add it to the
tests.

Signed-off-by: Dimitri John Ledkov <dimitri.ledkov@surgut.co.uk>
---
 ssl/t1_lib.c                     | 2 +-
 test/default-recordpadding.cnf   | 1 +
 test/default.cnf                 | 7 +++++++
 test/recipes/70-test_key_share.t | 3 +++
 4 files changed, 12 insertions(+), 1 deletion(-)

diff --git a/ssl/t1_lib.c b/ssl/t1_lib.c
index cd40fd13e8..24ea992e60 100644
--- a/ssl/t1_lib.c
+++ b/ssl/t1_lib.c
@@ -206,7 +206,7 @@ static const unsigned char ecformats_all[] = {
 /* Group list string of the built-in pseudo group DEFAULT */
 #define DEFAULT_GROUP_NAME "DEFAULT"
 #define TLS_DEFAULT_GROUP_LIST \
-    "?*X25519MLKEM768 / ?*X25519:?secp256r1 / ?X448:?secp384r1:?secp521r1 / ?ffdhe2048:?ffdhe3072"
+    "?X25519MLKEM768 / ?X25519:?secp256r1 / ?X448:?secp384r1:?secp521r1 / ?ffdhe2048:?ffdhe3072"
 
 static const uint16_t suiteb_curves[] = {
     OSSL_TLS_GROUP_ID_secp256r1,
diff --git a/test/default-recordpadding.cnf b/test/default-recordpadding.cnf
index a948e4359b..33e9d19141 100644
--- a/test/default-recordpadding.cnf
+++ b/test/default-recordpadding.cnf
@@ -15,6 +15,7 @@ system_default = system_default_section
 # always pad during datagram encryption
 [system_default_section]
 RecordPadding = 128,256
+Groups = ?*X25519MLKEM768 / ?*X25519:?secp256r1 / ?X448:?secp384r1:?secp521r1 / ?ffdhe2048:?ffdhe3072
 
 [provider_sect]
 default = default_sect
diff --git a/test/default.cnf b/test/default.cnf
index 21c7e070a9..8c040cc604 100644
--- a/test/default.cnf
+++ b/test/default.cnf
@@ -5,6 +5,7 @@ config_diagnostics = 1
 
 [openssl_init]
 providers = provider_sect
+ssl_conf = ssl_module
 
 [provider_sect]
 default = default_sect
@@ -15,3 +16,9 @@ activate = true
 
 [legacy_sect]
 activate = false
+
+[ssl_module]
+system_default = crypto_policy
+
+[crypto_policy]
+Groups = ?*X25519MLKEM768 / ?*X25519:?secp256r1 / ?X448:?secp384r1:?secp521r1 / ?ffdhe2048:?ffdhe3072
diff --git a/test/recipes/70-test_key_share.t b/test/recipes/70-test_key_share.t
index 998ae5d830..7092c3f409 100644
--- a/test/recipes/70-test_key_share.t
+++ b/test/recipes/70-test_key_share.t
@@ -49,6 +49,9 @@ my $selectedgroupid;
 my $test_name = "test_key_share";
 setup($test_name);
 
+my $defaultconf = srctop_file("test", "default.cnf");
+$ENV{OPENSSL_CONF} = $defaultconf;
+
 plan skip_all => "TLSProxy isn't usable on $^O"
     if $^O =~ /^(VMS)$/;
 
-- 
2.51.0

